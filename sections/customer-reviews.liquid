{{ 'customer-reviews.css' | asset_url | stylesheet_tag }}

{%- assign star_count = section.settings.star_count -%}

{%- comment -%} ── DESKTOP GRID ── {%- endcomment -%}
<section class="reviews">

  {%- if section.settings.heading != blank -%}
    <h2 class="reviews__heading">{{ section.settings.heading }}</h2>
  {%- endif -%}

  {%- comment -%} Desktop ── {%- endcomment -%}
  <div class="reviews__grid">
    {%- for block in section.blocks -%}
      {%- render 'review-card', block: block -%}
    {%- endfor -%}
  </div>

  {%- comment -%} Mobile slider ── {%- endcomment -%}
  <customer-reviews class="reviews__slider">
    <div class="reviews__slider-track" data-reviews-track>
      {%- for block in section.blocks -%}
        {%- render 'review-card', block: block -%}
      {%- endfor -%}
    </div>

    {%- if section.blocks.size > 1 -%}
      <div class="reviews__dots">
        {%- for block in section.blocks -%}
          <button
            class="reviews__dot{% if forloop.first %} is-active{% endif %}"
            data-reviews-dot
            type="button"
            aria-label="Go to review {{ forloop.index }}"
          ></button>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </customer-reviews>

</section>

<script src="{{ 'customer-reviews.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Customer Reviews",
  "tag": "section",
  "class": "section-customer-reviews",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Hear from our Customers!"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "image_picker",
          "id": "review_image",
          "label": "Review image"
        },
        {
          "type": "range",
          "id": "star_rating",
          "label": "Star rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "textarea",
          "id": "review_text",
          "label": "Review text",
          "default": "My indie is super picky and she LOVES these Bellie Bites by Wellie. Her breath smells fresher!"
        },
        {
          "type": "image_picker",
          "id": "avatar_image",
          "label": "Reviewer avatar"
        },
        {
          "type": "text",
          "id": "reviewer_name",
          "label": "Reviewer name",
          "default": "Mr. Marc John"
        }
      ]
    }
  ],
  "presets": [
    {
