{{ 'description.css' | asset_url | stylesheet_tag }}

<description-section>

  <section class="desc">

    {%- comment -%} ── HEADER ── {%- endcomment -%}
    <div class="desc__header">
      {%- if section.settings.heading != blank -%}
        <h2 class="desc__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="desc__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    {%- comment -%} ── VIDEOS ── {%- endcomment -%}
    {%- if section.blocks.size > 0 -%}
      <div class="desc__videos">
        {%- for block in section.blocks -%}
          <div class="desc__video-card" {{ block.shopify_attributes }}>

            {%- if block.settings.thumbnail != blank -%}
              <img
                class="desc__video-thumb"
                src="{{ block.settings.thumbnail | image_url: width: 600 }}"
                alt="Video {{ forloop.index }}"
                width="280"
                height="380"
                loading="lazy"
              >
            {%- else -%}
              <div class="desc__video-thumb" style="background:#ddd;"></div>
            {%- endif -%}

            {%- if block.settings.video_url != blank -%}
              <button
                class="desc__play-btn"
                data-desc-play="{{ block.settings.video_url }}"
                type="button"
                aria-label="Play video {{ forloop.index }}"
              >
                <span class="desc__play-icon">
                  <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <path d="M8 5v14l11-7z"/>
                  </svg>
                </span>
              </button>
            {%- endif -%}

          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- comment -%} ── DESCRIPTION BOX ── {%- endcomment -%}
    {%- if section.settings.show_description and product.description != blank -%}
      <div class="desc__box">
        <p class="desc__box-label">Description</p>
        <div class="desc__box-content">{{ product.description }}</div>
      </div>
    {%- endif -%}

  </section>

  {%- comment -%} ── VIDEO MODAL ── {%- endcomment -%}
  <div class="desc__modal" data-desc-modal>
    <div class="desc__modal-inner">
      <button class="desc__modal-close" data-desc-close type="button" aria-label="Close video">&times;</button>
      <iframe
        class="desc__modal-iframe"
        data-desc-iframe
        src=""
        allow="autoplay; fullscreen"
        allowfullscreen
      ></iframe>
    </div>
  </div>

</description-section>

<script src="{{ 'description.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Description",
  "tag": "section",
  "class": "section-description",
  "settings": [
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Love at First Bite."
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Real dogs. Real reactions. Zero convincing required."
    },
    {
      "type": "header",
      "content": "Description"
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "Show product description",
      "info": "Displays product.description from the product",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "video",
      "name": "Video",
      "settings": [
        {
          "type": "image_picker",
          "id": "thumbnail",
          "label": "Thumbnail image"
        },
        {
          "type": "url",
          "id": "video_url",
          "label": "Video URL",
          "info": "Paste a YouTube or Vimeo link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Description",
      "blocks": [
        { "type": "video" },
        { "type": "video" },
        { "type": "video" },
        { "type": "video" }
      ]
    }
  ],
  "max_blocks": 10
}
{% endschema %}
