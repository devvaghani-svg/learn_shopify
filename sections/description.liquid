{{ 'description.css' | asset_url | stylesheet_tag }}

<description-section>

  <section class="desc">

    {%- comment -%} ── HEADER ── {%- endcomment -%}
    <div class="desc__header">
      {%- if section.settings.heading != blank -%}
        <h2 class="desc__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="desc__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    {%- comment -%} ── VIDEOS ── {%- endcomment -%}
    {%- if section.blocks.size > 0 -%}
      <div class="desc__videos">
        {%- for block in section.blocks -%}
          <div class="desc__video-card" {{ block.shopify_attributes }}>
            {%- if block.settings.video != blank -%}
              {{- block.settings.video | video_tag:
                autoplay: true,
                loop: true,
                muted: true,
                playsinline: true,
                class: 'desc__video-el'
              -}}
            {%- else -%}
              <div class="desc__video-placeholder"></div>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- comment -%} ── DESCRIPTION BOX ── {%- endcomment -%}
    {%- if section.settings.show_description and product.description != blank -%}
      <div class="desc__box">
        <p class="desc__box-label">Description</p>
        <div class="desc__box-content is-collapsed" data-desc-content>{{ product.description }}</div>
        <button class="desc__read-more" data-desc-readmore type="button">Read more</button>
      </div>
    {%- endif -%}

  </section>


</description-section>

<script src="{{ 'description.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Description",
  "tag": "section",
  "class": "section-description",
  "settings": [
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Love at First Bite."
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Real dogs. Real reactions. Zero convincing required."
    },
    {
      "type": "header",
      "content": "Description"
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "Show product description",
      "info": "Displays product.description from the product",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "video",
      "name": "Video",
      "settings": [
        {
          "type": "video",
          "id": "video",
          "label": "Video"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Description",
      "blocks": [
        { "type": "video" },
        { "type": "video" },
        { "type": "video" },
        { "type": "video" }
      ]
    }
  ],
  "max_blocks": 10
}
{% endschema %}
