{{ 'faq.css' | asset_url | stylesheet_tag }}

<section class="faq">

  {%- if section.settings.heading != blank -%}
    <h2 class="faq__heading">{{ section.settings.heading }}</h2>
  {%- endif -%}

  <div class="faq__list">
    {%- assign faq_first = true -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'faq_item' -%}
        <details class="faq__item" {% if faq_first %}open{% endif %} {{ block.shopify_attributes }}>
        {%- assign faq_first = false -%}
          <summary class="faq__question">
            {{- block.settings.question -}}
            <span class="faq__icon" aria-hidden="true"></span>
          </summary>
          {%- if block.settings.answer != blank -%}
            <p class="faq__answer">{{ block.settings.answer }}</p>
          {%- endif -%}
        </details>
      {%- endif -%}
    {%- endfor -%}
  </div>

  {%- comment -%} ── Certificate strip ── {%- endcomment -%}
  {%- assign cert_blocks = section.blocks | where: 'type', 'certificate' -%}
  {%- if cert_blocks.size > 0 -%}
    <div class="faq__cert" style="--cert-bg: {{ section.settings.cert_bg_color }};">
      <div class="faq__cert-blob faq__cert-blob--tl" aria-hidden="true"></div>
      <div class="faq__cert-blob faq__cert-blob--br" aria-hidden="true"></div>
      {%- if section.settings.cert_heading != blank -%}
        <p class="faq__cert-heading">{{ section.settings.cert_heading }}</p>
      {%- endif -%}
      <div class="faq__cert-logos">
        {%- for block in cert_blocks -%}
          {%- if block.settings.image != blank -%}
            <img
              class="faq__cert-logo"
              src="{{ block.settings.image | image_url: width: 160 }}"
              alt="{{ block.settings.image_alt | default: 'Certificate' | escape }}"
              width="80"
              height="80"
              loading="lazy"
              {{ block.shopify_attributes }}
            >
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}

</section>

{% schema %}
{
  "name": "FAQ",
  "tag": "section",
  "class": "section-faq",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "FAQ's"
    },
    {
      "type": "text",
      "id": "cert_heading",
      "label": "Certificate strip heading",
      "default": "Certified & Trusted"
    },
    {
      "type": "color",
      "id": "cert_bg_color",
      "label": "Certificate background color",
      "default": "#C8DC6E"
    }
  ],
  "blocks": [
    {
      "type": "certificate",
      "name": "Certificate Badge",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Badge image"
        },
        {
          "type": "text",
          "id": "image_alt",
          "label": "Alt text"
        }
      ]
    },
    {
      "type": "faq_item",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "Can these treats replace my dog's regular diet?"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Answer",
          "default": "No, these treats are designed to supplement a balanced diet, not replace it. We recommend introducing these to your pet in addition to their current diet to see optimal results."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ",
      "blocks": [
        {
          "type": "faq_item",
          "settings": {
            "question": "Can these treats replace my dog's regular diet?",
            "answer": "No, these treats are designed to supplement a balanced diet, not replace it. We recommend introducing these to your pet in addition to their current diet to see optimal results."
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "I feed commercial food. Isn't that enough?",
            "answer": "Commercial food provides basic nutrition, but our treats add targeted support like probiotics, prebiotics, and enzymes that most commercial foods lack."
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "What's the difference from syrups or pills?",
            "answer": "Unlike syrups or pills, our treats are a natural, tasty format dogs love — no stress, no mess. Each chew delivers the same precise dose of active ingredients."
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "I give my dog curd - isn't that fine?",
            "answer": "Curd is a good source of probiotics, but it varies in potency and doesn't contain the prebiotics and digestive enzymes our chews provide for complete gut support."
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "Can I feed multiple types of your treats to my dog in a day?",
            "answer": "Yes! Our treats are formulated to work together. You can combine different variants as part of your dog's daily routine without worry."
          }
        }
      ]
    }
  ]
}
{% endschema %}
