{{ 'footer.css' | asset_url | stylesheet_tag }}

<footer class="footer" style="--footer-bg: {{ section.settings.bg_color }};">

  <a href="#" class="footer__back-top footer__back-top--mobile" onclick="window.scrollTo({top:0,behavior:'smooth'});return false;">
    <img src="{{ 'arrow.svg' | asset_url }}" alt="" width="21" height="21" aria-hidden="true">
    Back to Top
  </a>

  <div class="footer__grid">

    {%- comment -%} ── Col 1: Brand ── {%- endcomment -%}
    <div class="footer__brand">
      {%- if section.settings.logo_image != blank -%}
        <a href="/" class="footer__logo-link">
          <img
            class="footer__logo-img"
            src="{{ section.settings.logo_image | image_url: width: 300 }}"
            alt="{{ section.settings.logo_image.alt | default: shop.name | escape }}"
            width="160"
            loading="lazy"
          >
        </a>
      {%- endif -%}
      {%- if section.settings.description != blank -%}
        <p class="footer__desc">{{ section.settings.description }}</p>
      {%- endif -%}
      <div class="footer__socials">
        {%- if section.settings.facebook_url != blank -%}
          <a href="{{ section.settings.facebook_url }}" class="footer__social-link" aria-label="Facebook" target="_blank" rel="noopener">
            {%- if section.settings.facebook_icon != blank -%}
              <img src="{{ section.settings.facebook_icon | image_url: width: 80 }}" alt="Facebook" width="20" height="20">
            {%- else -%}
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
            {%- endif -%}
          </a>
        {%- endif -%}
        {%- if section.settings.instagram_url != blank -%}
          <a href="{{ section.settings.instagram_url }}" class="footer__social-link" aria-label="Instagram" target="_blank" rel="noopener">
            {%- if section.settings.instagram_icon != blank -%}
              <img src="{{ section.settings.instagram_icon | image_url: width: 80 }}" alt="Instagram" width="20" height="20">
            {%- else -%}
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
            {%- endif -%}
          </a>
        {%- endif -%}
        {%- if section.settings.twitter_url != blank -%}
          <a href="{{ section.settings.twitter_url }}" class="footer__social-link" aria-label="X (Twitter)" target="_blank" rel="noopener">
            {%- if section.settings.twitter_icon != blank -%}
              <img src="{{ section.settings.twitter_icon | image_url: width: 80 }}" alt="X" width="20" height="20">
            {%- else -%}
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            {%- endif -%}
          </a>
        {%- endif -%}
        {%- if section.settings.youtube_url != blank -%}
          <a href="{{ section.settings.youtube_url }}" class="footer__social-link" aria-label="YouTube" target="_blank" rel="noopener">
            {%- if section.settings.youtube_icon != blank -%}
              <img src="{{ section.settings.youtube_icon | image_url: width: 80 }}" alt="YouTube" width="20" height="20">
            {%- else -%}
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46A2.78 2.78 0 0 0 1.46 6.42 29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58 2.78 2.78 0 0 0 1.95 1.96C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.96A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58zM9.75 15.02V8.98L15.5 12z"/></svg>
            {%- endif -%}
          </a>
        {%- endif -%}
      </div>
    </div>

    {%- comment -%} ── Col 2 & 3: Nav columns wrapped for mobile 2-col sub-grid ── {%- endcomment -%}
    <div class="footer__nav-cols">
      <div class="footer__nav">
        <h3 class="footer__nav-heading">{{ section.settings.company_heading }}</h3>
        <ul class="footer__nav-list">
          {%- for link in section.settings.company_menu.links -%}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {%- endfor -%}
        </ul>
      </div>

      <div class="footer__nav">
        <h3 class="footer__nav-heading">{{ section.settings.products_heading }}</h3>
        <ul class="footer__nav-list">
          {%- for link in section.settings.products_menu.links -%}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {%- endfor -%}
        </ul>
      </div>
    </div>

    {%- comment -%} ── Col 4: Contact ── {%- endcomment -%}
    <div class="footer__contact-col">
      <a href="#" class="footer__back-top" onclick="window.scrollTo({top:0,behavior:'smooth'});return false;">
        <img src="{{ 'arrow.svg' | asset_url }}" alt="" width="14" height="14" aria-hidden="true">
        Back to Top
      </a>
      {%- if section.settings.contact_heading != blank -%}
        <h3 class="footer__contact-heading">{{ section.settings.contact_heading }}</h3>
      {%- endif -%}
      {%- if section.settings.contact_sub != blank -%}
        <p class="footer__contact-sub">{{ section.settings.contact_sub }}</p>
      {%- endif -%}
      <div class="footer__contact-row">
        {%- if section.settings.email != blank -%}
          <span class="footer__contact-item"><strong>Email:</strong> {{ section.settings.email }}</span>
        {%- endif -%}
        {%- if section.settings.phone != blank -%}
          <span class="footer__contact-item"><strong>Phone:</strong> {{ section.settings.phone }}</span>
        {%- endif -%}
      </div>
      {%- if section.settings.operating_hours != blank -%}
        <p class="footer__hours-heading">Operating Hours:</p>
        <p class="footer__hours">{{ section.settings.operating_hours }}</p>
      {%- endif -%}
    </div>

  </div>

  {%- comment -%} ── Bottom bar ── {%- endcomment -%}
  <div class="footer__bottom">
    <p class="footer__copyright">{{ section.settings.copyright }}</p>
  </div>

</footer>

{% schema %}
{
  "name": "Footer",
  "class": "footer-section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#025A60"
    },
    {
      "type": "image_picker",
      "id": "logo_image",
      "label": "Logo image"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Brand description",
      "default": "Lorem Ipsum is simply dummy text of the printing and typesetting industry. Lorem Ipsum has been the industry's standard dummy text ever since the 1500s,"
    },
    {
      "type": "header",
      "content": "Social Links"
    },
    {
      "type": "image_picker",
      "id": "facebook_icon",
      "label": "Facebook icon image"
    },
    {
      "type": "url",
      "id": "facebook_url",
      "label": "Facebook URL"
    },
    {
      "type": "image_picker",
      "id": "instagram_icon",
      "label": "Instagram icon image"
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram URL"
    },
    {
      "type": "image_picker",
      "id": "twitter_icon",
      "label": "X (Twitter) icon image"
    },
    {
      "type": "url",
      "id": "twitter_url",
      "label": "X (Twitter) URL"
    },
    {
      "type": "image_picker",
      "id": "youtube_icon",
      "label": "YouTube icon image"
    },
    {
      "type": "url",
      "id": "youtube_url",
      "label": "YouTube URL"
    },
    {
      "type": "header",
      "content": "Navigation"
    },
    {
      "type": "text",
      "id": "company_heading",
      "label": "Company column heading",
      "default": "Company"
    },
    {
      "type": "link_list",
      "id": "company_menu",
      "label": "Company menu"
    },
    {
      "type": "text",
      "id": "products_heading",
      "label": "Products column heading",
      "default": "Products"
    },
    {
      "type": "link_list",
      "id": "products_menu",
      "label": "Products menu"
    },
    {
      "type": "header",
      "content": "Contact"
    },
    {
      "type": "text",
      "id": "contact_heading",
      "label": "Contact heading",
      "default": "Want to get in touch?"
    },
    {
      "type": "textarea",
      "id": "contact_sub",
      "label": "Contact subtext",
      "default": "We'd love to hear from you!\nFor any feedback or queries, contact us on :"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Email",
      "default": "raya@wellie.in"
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Phone",
      "default": "+91 97407 57184"
    },
    {
      "type": "text",
      "id": "operating_hours",
      "label": "Operating hours",
      "default": "Mon- Sun, 10am to 6pm"
    },
    {
      "type": "header",
      "content": "Bottom bar"
    },
    {
      "type": "text",
      "id": "copyright",
      "label": "Copyright text",
      "default": "© 2025 Wellie. Powered by Shopify."
    }
  ],
  "presets": [
    {
      "name": "Footer"
    }
  ]
}
{% endschema %}
