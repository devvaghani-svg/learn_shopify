{{ 'header.css' | asset_url | stylesheet_tag}}

<header class="site-header" role="banner">
  <div class="site-header__inner">

    {%- comment -%} Left slot {%- endcomment -%}
    <div class="site-header__left">
      {%- comment -%} Desktop: logo {%- endcomment -%}
      <div class="site-header__logo-desktop">
        <a href="{{ routes.root_url }}" aria-label="{{ shop.name }}">
          {%- if settings.logo != blank -%}
            {% render 'logo', class_name: 'site-header__logo-img' %}
          {%- else -%}
            <span class="site-header__logo-text">{{ shop.name }}</span>
          {%- endif -%}
        </a>
      </div>

      {%- comment -%} Mobile: hamburger (dot-grid) {%- endcomment -%}
      <button
        type="button"
        class="site-header__hamburger"
        aria-label="Open menu"
        aria-expanded="false"
        data-menu-toggle
      >
        <svg width="22" height="22" viewBox="0 0 22 22" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="7" cy="5.5" r="2" fill="#1d5c58"/>
          <circle cx="15" cy="5.5" r="2" fill="#1d5c58"/>
          <circle cx="7" cy="11" r="2" fill="#1d5c58"/>
          <circle cx="15" cy="11" r="2" fill="#1d5c58"/>
          <circle cx="7" cy="16.5" r="2" fill="#1d5c58"/>
          <circle cx="15" cy="16.5" r="2" fill="#1d5c58"/>
        </svg>
      </button>
    </div>

    {%- comment -%} Center slot {%- endcomment -%}
    <div class="site-header__center">
      {%- comment -%} Mobile: logo centered {%- endcomment -%}
      <div class="site-header__logo-mobile">
        <a href="{{ routes.root_url }}" aria-label="{{ shop.name }}">
          {%- if settings.logo != blank -%}
            {% render 'logo', class_name: 'site-header__logo-img' %}
          {%- else -%}
            <span class="site-header__logo-text">{{ shop.name }}</span>
          {%- endif -%}
        </a>
      </div>

      {%- comment -%} Desktop: navigation {%- endcomment -%}
      <nav aria-label="Main navigation">
        <ul class="site-header__nav">
          <li class="site-header__nav-item">
            <a href="{{ routes.root_url }}" class="site-header__nav-link">Home</a>
          </li>
          <li class="site-header__nav-item">
            <span class="site-header__nav-link">
              Shop
              <svg class="site-header__nav-chevron" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M2.625 5.25L7 9.625L11.375 5.25" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
            <ul class="site-header__dropdown">
              {%- for link in section.settings.menu.links -%}
                {%- if link.title == 'Shop' or link.title == 'shop' -%}
                  {%- for child_link in link.links -%}
                    <li>
                      <a href="{{ child_link.url }}" class="site-header__dropdown-link">{{ child_link.title }}</a>
                    </li>
                  {%- endfor -%}
                {%- endif -%}
              {%- endfor -%}
            </ul>
          </li>
          <li class="site-header__nav-item">
            <a href="/pages/about-us" class="site-header__nav-link">About Us</a>
          </li>
          <li class="site-header__nav-item">
            <a href="/pages/contact" class="site-header__nav-link">Contact us</a>
          </li>
        </ul>
      </nav>
    </div>

    {%- comment -%} Right slot: icons {%- endcomment -%}
    <div class="site-header__right">
      <button type="button" class="site-header__icon-btn" aria-label="Search">
        {{ 'search.svg' | asset_url | img_tag }}
      </button>

      <button type="button" class="site-header__icon-btn site-header__icon-account" aria-label="Account">
        {{ 'account.svg' | asset_url | img_tag }}
      </button>

      <button
        type="button"
        class="site-header__icon-btn"
        aria-label="Open cart"
        data-cart-open-trigger
      >
        {{ 'cart.svg' | asset_url | img_tag }}
        {%- if cart.item_count > 0 -%}
          <span class="site-header__cart-count">{{ cart.item_count }}</span>
        {%- endif -%}
      </button>
    </div>

  </div>
</header>

{%- comment -%} Mobile drawer navigation {%- endcomment -%}
<nav
  class="site-header__mobile-menu"
  data-mobile-menu
  aria-label="Mobile navigation"
>
  <div class="site-header__mobile-menu-inner">
    <button
      type="button"
      class="site-header__mobile-close"
      aria-label="Close menu"
      data-menu-close
    >
      {% render 'icon-close', color: '#1d5c58' %}
    </button>

    <ul class="site-header__mobile-nav">
      <li class="site-header__mobile-nav-item">
        <a href="{{ routes.root_url }}" class="site-header__mobile-nav-link">Home</a>
      </li>
      <li class="site-header__mobile-nav-item">
        <button
          type="button"
          class="site-header__mobile-submenu-toggle"
          aria-expanded="false"
          data-submenu-toggle
        >
          <span>Shop</span>
          <svg class="site-header__mobile-chevron" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M2.625 5.25L7 9.625L11.375 5.25" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <ul class="site-header__mobile-submenu">
          {%- for link in section.settings.menu.links -%}
            {%- if link.title == 'Shop' or link.title == 'shop' -%}
              {%- for child_link in link.links -%}
                <li>
                  <a href="{{ child_link.url }}" class="site-header__mobile-submenu-link">{{ child_link.title }}</a>
                </li>
              {%- endfor -%}
            {%- endif -%}
          {%- endfor -%}
        </ul>
      </li>
      <li class="site-header__mobile-nav-item">
        <a href="/pages/about-us" class="site-header__mobile-nav-link">About Us</a>
      </li>
      <li class="site-header__mobile-nav-item">
        <a href="/pages/contact" class="site-header__mobile-nav-link">Contact us</a>
      </li>
    </ul>
  </div>
</nav>

<div class="site-header__overlay" data-mobile-overlay aria-hidden="true"></div>

<script src="{{ 'header-javascript.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "t:general.header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:labels.menu"
    }
  ],
  "presets": [
    {
      "name": "Header"
    }
  ]
}
{% endschema %}
