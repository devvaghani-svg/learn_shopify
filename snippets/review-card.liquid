{%- comment -%}
  Renders a single review card.
  Accepts:
    - block: {Object} section block with settings
{%- endcomment -%}

<div class="reviews__card" {{ block.shopify_attributes }}>

  {%- comment -%} Child 1: Image {%- endcomment -%}
  <div class="reviews__card-media">
    {%- if block.settings.review_image != blank -%}
      <img
        class="reviews__card-img"
        src="{{ block.settings.review_image | image_url: width: 300 }}"
        alt="{{ block.settings.reviewer_name | escape }}"
        width="146"
        height="200"
        loading="lazy"
      >
    {%- endif -%}
  </div>

  {%- comment -%} Child 2: Data {%- endcomment -%}
  <div class="reviews__card-body">

    <span class="reviews__quote" aria-hidden="true">{{ 'quata.svg' | asset_url | img_tag }}</span>

    <div class="reviews__stars" aria-label="{{ block.settings.star_rating }} out of 5 stars">
      {%- for i in (1..5) -%}
        <svg class="reviews__star{% if i > block.settings.star_rating %} reviews__star--empty{% endif %}" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
        </svg>
      {%- endfor -%}
    </div>

    {%- if block.settings.review_text != blank -%}
      <p class="reviews__text">{{ block.settings.review_text }}</p>
    {%- endif -%}

    <div class="reviews__author">
      {%- if block.settings.avatar_image != blank -%}
        <img
          class="reviews__avatar"
          src="{{ block.settings.avatar_image | image_url: width: 72 }}"
          alt="{{ block.settings.reviewer_name | escape }}"
          width="28"
          height="28"
          loading="lazy"
        >
      {%- endif -%}
      {%- if block.settings.reviewer_name != blank -%}
        <span class="reviews__name">{{ block.settings.reviewer_name }}</span>
      {%- endif -%}
    </div>

  </div>

</div>
